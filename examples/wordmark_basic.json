{
  "1": {
    "class_type": "WordmarkGenerator",
    "_meta": { "title": "Generate wordmark variants" },
    "inputs": {
      "text": "WORDMARK",
      "font_path": "",
      "font_size": 96,
      "text_color": "#000000",
      "style_preset": "wide",
      "letter_spacing": 0,
      "padding": 20,
      "variant_count": 3,
      "variant_spacing_step": 10
    }
  },
  "2": {
    "class_type": "AlphaPrepDropShadow",
    "_meta": { "title": "Drop shadow" },
    "inputs": {
      "image": ["1", 0],
      "mask": ["1", 1],
      "offset_x": 6,
      "offset_y": 6,
      "blur_radius": 8,
      "shadow_color": "#000000",
      "shadow_opacity": 0.5
    }
  },
  "3": {
    "class_type": "SaveImage",
    "_meta": { "title": "Save wordmark variants" },
    "inputs": { "images": ["2", 0], "filename_prefix": "wordmark" }
  },
  "4": {
    "class_type": "AlphaPrepPreviewBackground",
    "_meta": { "title": "Preview on checkerboard" },
    "inputs": {
      "image": ["2", 0],
      "mask": ["2", 1],
      "background": "checkerboard",
      "color": "#FFFFFF",
      "checker_size": 16
    }
  },
  "5": {
    "class_type": "PreviewImage",
    "_meta": { "title": "Preview in UI" },
    "inputs": { "images": ["4", 0] }
  }
}
