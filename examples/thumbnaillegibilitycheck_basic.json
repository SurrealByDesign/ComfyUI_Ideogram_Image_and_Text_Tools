{
  "1": {
    "class_type": "LoadImage",
    "_meta": { "title": "Load source logo" },
    "inputs": { "image": "logo.png" }
  },
  "2": {
    "class_type": "AlphaPrepMaskAdapter",
    "_meta": {
      "title": "Convert LoadImage's inpainting-style mask to AlphaPrep's alpha convention"
    },
    "inputs": { "image": ["1", 0], "mask": ["1", 1] }
  },
  "3": {
    "class_type": "AlphaPrepTrim",
    "_meta": { "title": "Trim transparent border" },
    "inputs": { "image": ["2", 0], "mask": ["2", 1], "alpha_threshold": 0.0, "padding": 0 }
  },
  "4": {
    "class_type": "ThumbnailLegibilityCheck",
    "_meta": { "title": "Check legibility at 256/128/64/32px" },
    "inputs": {
      "image": ["3", 0],
      "mask": ["3", 1],
      "sizes": "256x256\n128x128\n64x64\n32x32",
      "background": "checkerboard",
      "color": "#FFFFFF",
      "checker_size": 8,
      "label_color": "#000000"
    }
  },
  "5": {
    "class_type": "PreviewImage",
    "_meta": { "title": "Preview comparison strip in UI" },
    "inputs": { "images": ["4", 0] }
  }
}
